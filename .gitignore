# Ignore files generated by the IDEs
.idea/
.vscode/

# Ignore system and OS-generated files
.DS_Store
Thumbs.db

# Ignore compiled files and build artifacts
*.pyc
*.npy
*.pyo
*.pyd
__pycache__/
*.class
*.jar
*.war
*.ear
*.exe
*.dll
*.so
*.out
*.log
*.png
*.err
*.csv

# ignor wav
*.wav
# Ignore dependency directories
node_modules/
bower_components/
vendor/

# Ignore sensitive or private information
config.ini
secrets.txt

# Ignore files specific to your development environment
.env
.venv
# Ignore package manager lock files
yarn.lock
package-lock.json
pip-lock.txt

# Ignore macOS file metadata
# Comment the next line if you use macOS and want to keep file metadata
*._DS_Store
*.key
log_**

data
!transformer/data
figures
plots
*.key

*.pkl


